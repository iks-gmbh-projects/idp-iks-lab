{
  "name": "IDP IKS Lab",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "customizations": {
    "vscode": {
      "settings": {
        "editor.detectIndentation": false,
        "editor.formatOnSave": false,
        "editor.insertSpaces": true,
        "editor.tabSize": 2,
        "files.eol": "\n",
        "files.encoding": "utf8"
      },
      "extensions": [
        "EditorConfig.EditorConfig",
        "redhat.vscode-yaml"
      ]
    }
  },
  "remoteUser": "node"
}
