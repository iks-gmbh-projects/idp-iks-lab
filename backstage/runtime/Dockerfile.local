FROM node:24-bookworm-slim

RUN apt-get update \
  && apt-get install -y --no-install-recommends \
    build-essential \
    ca-certificates \
    git \
    libsqlite3-dev \
    pkg-config \
    python3 \
  && rm -rf /var/lib/apt/lists/*

RUN corepack enable
RUN mkdir -p /home/node/.cache/node/corepack /home/node/.cache/yarn \
  && chown -R node:node /home/node/.cache

USER node
WORKDIR /workspace/iks-backstage-runtime
